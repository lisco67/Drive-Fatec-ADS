   124     02 FILLER          PIC X(5) VALUE SPACES.
   125     02 VAR-MSG-ERRO        PIC X(35).
   126
   127 PROCEDURE DIVISION.
   128 PGM-04.
   129 PERFORM INICIO.
   130 PERFORM PRINCIPAL
   131     UNTIL CH-CADMERC EQUAL CH-MOVMERC AND
   132     CH-MOVMERC EQUAL   HIGH-VALUES.
   133 PERFORM FIM.
   134 STOP RUN.
   135 INICIO.
   136     OPEN INPUT CADMERC
   137                MOVMERC
   138          OUTPUT ATUMERC RELERRO RELMERC.
   139     PERFORM LER-CADMERC.
   140     PERFORM LER-MOVMERC.
   141
   142 LER-CADMERC.
   143     READ CADMERC AT END MOVE HIGH-VALUE TO CH-CADMERC.
   144     IF  NOT(CH-CADMERC EQUAL HIGH-VALUE)
   145         MOVE CODMERC-CAD TO CH-CADMERC
   146     END-IF.
   147 LER-MOVMERC.
   148     READ MOVMERC AT END MOVE HIGH-VALUE TO CH-MOVMERC.
   149     IF  NOT(CH-MOVMERC EQUAL HIGH-VALUE)
   150         MOVE CODMERC-MOV TO CH-MOVMERC
   151     END-IF.
   152 PRINCIPAL.
   153     IF TIPO-MOV EQUAL "I" OR TIPO-MOV EQUAL "E" OR TIPO-MOV
   154                                                    EQUAL "A"
   155         IF CH-CADMERC EQUAL CH-MOVMERC
   156             PERFORM IGUAL
   157             PERFORM LER-CADMERC
   158             PERFORM LER-MOVMERC
   159         ELSE IF CH-CADMERC LESS CH-MOVMERC
   160             PERFORM CADMERC-MENOR
   161             PERFORM LER-CADMERC
   162         ELSE IF CH-MOVMERC LESS CH-CADMERC
   163             PERFORM MOVMERC-MENOR
   164             PERFORM LER-MOVMERC
   165         END-IF
   166     ELSE
   167         PERFORM LER-MOVMERC
   168     END-IF.
   169
   170 IGUAL.
   171     IF TIPO-MOV EQUAL "I"
   172         MOVE "EI" TO CH-TYPE
   173         PERFORM GRAVACAO-REL-ERRO
* Microsoft COBOL Version 4.5        L2.4 revision 002 16-Jun-25 16:17 Page   4
*                                      EXERC3.CBL
   174         PERFORM GRAVACAO-SAIDA-2
   175     ELSE IF TIPO-MOV EQUAL "A"
   176         IF QUANTESTOQ-MOV LESS ESTOQMIN-MOV OR QUANTESTOQ-MOV
   177                       EQUAL ESTOQMIN-MOV
   178             PERFORM GRAVACAO-REL-MERC
   179             END-IF
   180         MOVE "EA" TO CH-TYPE
   181         PERFORM GRAVACAO-SAIDA-1
   182     ELSE IF TIPO-MOV EQUAL "E"
   183         MOVE "EE" TO CH-TYPE
   184     END-IF.
   185 MOVMERC-MENOR.
   186     IF TIPO-MOV EQUAL "I"
   187         IF QUANTESTOQ-MOV LESS ESTOQMIN-MOV OR QUANTESTOQ-MOV
   188                         EQUAL ESTOQMIN-MOV
   189             PERFORM GRAVACAO-REL-MERC
   190             END-IF
   191         PERFORM GRAVACAO-SAIDA-1
   192     ELSE IF TIPO-MOV EQUAL "A"
   193         MOVE "MA" TO CH-TYPE
   194         PERFORM GRAVACAO-REL-ERRO
   195     ELSE IF TIPO-MOV EQUAL "E"
   196         MOVE "ME" TO CH-TYPE
   197         PERFORM GRAVACAO-REL-ERRO
   198     END-IF.
   199 CADMERC-MENOR.
   200     PERFORM GRAVACAO-SAIDA-2.
   201 GRAVACAO-SAIDA-1.
   202     WRITE REG-ATU FROM REG-MOV.
   203 GRAVACAO-SAIDA-2.
   204     WRITE REG-ATU FROM REG-CAD.
   205 GRAVACAO-REL-MERC.
   206     IF CT-LIN-MERC GREATER THAN 39
   207         PERFORM CABECALHO-MERC
   208     END-IF.
   209     PERFORM DETALHES-MERC.
   210 GRAVACAO-REL-ERRO.
   211     IF CT-LIN-ERRO GREATER THAN 39
   212         PERFORM CABECALHO-ERRO
   213     END-IF.
   214     PERFORM DETALHES-ERRO.
   215 DETALHES-ERRO.
   216     MOVE CODMERC-MOV TO VAR-COD-ERRO
   217     MOVE DESC-MOV TO VAR-DESCR-ERRO
   218     IF CH-TYPE EQUAL "EI"
   219         MOVE "INCLUSĂO P/REG. JÁ EXISTENTE" TO VAR-MSG-ERRO
   220     ELSE IF CH-TYPE EQUAL "MA"
   221         MOVE "ALTERAÇĂO P/REG. INEXISTENTE" TO VAR-MSG-ERRO
   222     ELSE IF CH-TYPE EQUAL "ME"
   223         MOVE "EXCLUSĂO P/REG. INEXISTENTE" TO VAR-MSG-ERRO
   224     END-IF.
   225     WRITE REG-ERRO FROM DETALHE-ERRO AFTER ADVANCING 1 LINE
   226     ADD 1 TO CT-LIN-ERRO.
   227 DETALHES-MERC.
   228     MOVE CODMERC-MOV TO VAR-COD-MERC.
   229     MOVE DESC-MOV TO VAR-DESCR.
   230     MOVE ESTOQMIN-MOV TO VAR-ESTOQMIN.
   231     MOVE QUANTESTOQ-MOV TO VAR-ESTOQQUAN.
* Microsoft COBOL Version 4.5        L2.4 revision 002 16-Jun-25 16:17 Page   5
*                                      EXERC3.CBL
   232     MOVE UNITARIO-MOV TO VAR-UNITARIO
   233     WRITE REG-MERC FROM DETALHE-MERC AFTER ADVANCING 1 LINE
   234     ADD 1 TO CT-LIN-MERC.
   235
   236 CABECALHO-MERC.
   237     ADD 1         TO CT-PAG-MERC.
   238     MOVE CT-PAG-MERC   TO VAR-PAG-MERC.
   239     MOVE SPACES   TO REG-MERC.
   240     WRITE REG-MERC AFTER ADVANCING PAGE.
   241     WRITE REG-MERC FROM CAB01-MERC AFTER ADVANCING 1 LINE.
   242     WRITE REG-MERC FROM WHITE-CAB01 AFTER ADVANCING 1 LINE.
   243     WRITE REG-MERC FROM CAB02-MERC AFTER ADVANCING 1 LINE.
   244     WRITE REG-MERC FROM CAB03-MERC AFTER ADVANCING 1 LINE.
   245     WRITE REG-MERC FROM WHITE-CAB01 AFTER ADVANCING 1 LINE.
   246     MOVE 6  TO CT-LIN-MERC.
   247 CABECALHO-ERRO.
   248     ADD 1         TO CT-PAG-ERRO.
   249     MOVE CT-PAG-ERRO   TO VAR-PAG-ERRO.
   250     MOVE SPACES   TO REG-ERRO.
   251     WRITE REG-ERRO AFTER ADVANCING PAGE.
   252     WRITE REG-ERRO FROM CAB01-ERRO AFTER ADVANCING 1 LINE.
   253     WRITE REG-ERRO FROM WHITE-CAB02 AFTER ADVANCING 1 LINE.
   254     WRITE REG-ERRO FROM CAB02-ERRO AFTER ADVANCING 1 LINE.
   255     WRITE REG-ERRO FROM CAB03-ERRO AFTER ADVANCING 1 LINE.
   256     WRITE REG-ERRO FROM WHITE-CAB02 AFTER ADVANCING 1 LINE.
   257     MOVE 6  TO CT-LIN-ERRO.
   258
   259 FIM.
   260      CLOSE CADMERC MOVMERC RELMERC ATUMERC RELERRO.
